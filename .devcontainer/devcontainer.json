{
    "name": "Ansible Dev Container",
    "image": "ghcr.io/organicveggie/ansible-devcontainer:latest",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "redhat.ansible",
                "ms-python.python",
                "redhat.vscode-yaml",
                "samuelcolvin.jinjahtml"
            ]
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest",
            "enableNonRootDocker": "true",
            // Trixie does not include moby-cli, so we need to disable it here to avoid errors about missing moby packages.
            "moby": false
        }
    },
    // Use 'postCreateCommand' to run commands after the container is created.
    "postCreateCommand": "python --version && ansible --version"
}